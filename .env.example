# Shared deployment reference for clearSKY AI.
# Copy service-specific values into Vercel, Render, Neon, Cloudinary, and Supabase dashboards.

# Public URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
# Leave blank locally for SQLite fallback. Set in production from Neon.
DATABASE_URL=
SQLITE_DATABASE_PATH=.local/clearsky.db
AUTO_CREATE_TABLES=true

# Storage: local | cloudinary | supabase
STORAGE_PROVIDER=local
UPLOAD_DIR=.local/uploads
INFERENCE_DIR=.local/inference
SERVED_FILES_ENABLED=true
CLOUDINARY_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=clearsky

# Uploads
MAX_UPLOAD_SIZE_MB=512
ALLOWED_UPLOAD_EXTENSIONS=.tif,.tiff,.zip
ALLOWED_INFERENCE_EXTENSIONS=.png,.jpg,.jpeg,.tif,.tiff,.jp2,.j2k
MAX_INFERENCE_DIMENSION=2048
MAX_INFERENCE_PIXELS=25000000

# API
APP_ENV=development
API_INTERNAL_TOKEN=change-me
JWT_SECRET=replace-with-a-long-random-production-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
DEFAULT_USER_STORAGE_QUOTA_MB=512
LOG_LEVEL=INFO
